# ─────────────────────────────────────────────────────────────
# FL-CL Experiment Configuration Template
# ─────────────────────────────────────────────────────────────
# This file defines all tunable parameters for a single FL-CL
# experiment run. Copy this to configs/experiment.yaml and fill
# in details (like Telegram keys) for your local environment.
# ─────────────────────────────────────────────────────────────

experiment:
  name: "FL-CL-EWC-Baseline"
  description: "Federated Continual Learning with EWC on 5-class encrypted traffic"

# ── Federated Learning ──────────────────────────────────────
fl:
  rounds: 100
  min_clients: 2
  fraction_fit: 1.0
  fraction_evaluate: 1.0

# ── Continual Learning (EWC) ────────────────────────────────
cl:
  strategy: "EWC"
  ewc_lambda: 0.4

# ── Model Architecture ──────────────────────────────────────
model:
  input_dim: 32
  num_classes: 5
  hidden_layers: [64, 32]
  dropout: 0.2

# ── Training Hyperparameters ────────────────────────────────
training:
  optimizer: "SGD"
  lr: 0.01
  momentum: 0.9
  batch_size: 32
  epochs_per_round: 1
  class_weights: [10.0, 3.0, 3.0, 8.0, 1.0]

# ── Feature Engineering ─────────────────────────────────────
features:
  columns:
    - bidirectional_packets
    - bidirectional_bytes
    - duration_ms
    - src2dst_packets
    - src2dst_bytes
    - dst2src_packets
    - dst2src_bytes
    - src2dst_mean_piat_ms
    - dst2src_mean_piat_ms
    - dst_port

# ── Traffic Simulation ──────────────────────────────────────
simulation:
  attack_duration_seconds: 30
  stages:
    - mode: benign
    - mode: ssh
    - mode: slowloris
    - mode: dns_exfil
    - mode: botnet

# ── Network Topology (Proxmox Testbed) ──────────────────────
topology:
  aggregator: "10.10.130.10"
  defender_a: "10.10.130.11"
  defender_b: "10.10.130.12"
  target_a: "10.10.110.15"
  target_b: "10.10.120.15"
  traffic_gen: "10.10.140.10"
  flower_port: 8080
  mlflow_port: 5000

# ── Notifications ───────────────────────────────────────────
notifications:
  telegram:
    enabled: false
    bot_token: "YOUR_TELEGRAM_BOT_TOKEN"
    chat_id: "YOUR_TELEGRAM_CHAT_ID"

# ── Checkpointing ──────────────────────────────────────────
checkpointing:
  save_dir: "/opt/mlflow-artifacts/checkpoints"
  save_best: true
  export_torchscript: true

# ── MLOps Mode Configuration ────────────────────────────────
mlops:
  # Model registry reference name in MLflow
  registered_model_name: "CyberDefenseNet"

# ── Labeling Configuration ──────────────────────────────────
labeling:
  dos_duration_threshold_ms: 2000

